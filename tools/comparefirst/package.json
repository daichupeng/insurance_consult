{
  "name": "comparefirst-scraper",
  "version": "1.0.0",
  "description": "Scrape insurance policy facts from comparefirst.sg using Stagehand",
  "type": "module",
  "scripts": {
    "scrape": "npx tsx scraper.ts",
    "scrape:term": "npx tsx scraper.ts --type term",
    "scrape:whole": "npx tsx scraper.ts --type whole",
    "scrape:endowment": "npx tsx scraper.ts --type endowment",
    "scrape:ilp": "npx tsx scraper.ts --type ilp"
  },
  "dependencies": {
    "@browserbasehq/stagehand": "^1.13.0",
    "dotenv": "^17.3.1",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
